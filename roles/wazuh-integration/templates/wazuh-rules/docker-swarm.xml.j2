<!-- Managed by mash-nextgen — Docker Swarm monitoring rules -->
<group name="docker,swarm,containers">

  <rule id="100350" level="5">
    <decoded_as>docker-container-event</decoded_as>
    <match>die|kill|oom</match>
    <description>Docker: Container $(user) died/killed ($(action))</description>
    <group>docker,container_death</group>
  </rule>

  <rule id="100351" level="10" frequency="5" timeframe="600">
    <if_matched_sid>100350</if_matched_sid>
    <same_field>user</same_field>
    <description>Docker: Container $(user) crash loop — 5+ deaths in 10 minutes</description>
    <group>docker,crash_loop</group>
  </rule>

  <rule id="100352" level="8">
    <decoded_as>docker-health-check</decoded_as>
    <match>unhealthy</match>
    <description>Docker: Container $(extra_data) health check UNHEALTHY</description>
    <group>docker,health_check</group>
  </rule>

  <rule id="100353" level="3">
    <decoded_as>docker-container-event</decoded_as>
    <match>start</match>
    <description>Docker: Container $(user) started</description>
    <group>docker,container_start</group>
  </rule>

  <rule id="100354" level="5">
    <decoded_as>docker-container-event</decoded_as>
    <match>stop</match>
    <description>Docker: Container $(user) stopped</description>
    <group>docker,container_stop</group>
  </rule>

</group>
