<!-- Managed by mash-nextgen — Authentik SSO security rules -->
<group name="authentik,sso,authentication">

  <rule id="100110" level="5">
    <decoded_as>authentik-login-failed</decoded_as>
    <description>Authentik: Failed SSO login for $(user) from $(srcip)</description>
    <group>authentication_failed,authentik</group>
  </rule>

  <rule id="100111" level="10" frequency="5" timeframe="300">
    <if_matched_sid>100110</if_matched_sid>
    <same_source_ip/>
    <description>Authentik: SSO brute force — 5+ failed logins from $(srcip)</description>
    <group>authentication_failed,authentik,brute_force</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="100112" level="3">
    <decoded_as>authentik-login-success</decoded_as>
    <description>Authentik: Successful SSO login for $(user) from $(srcip)</description>
    <group>authentication_success,authentik</group>
  </rule>

  <rule id="100113" level="8">
    <decoded_as>authentik-token-failed</decoded_as>
    <description>Authentik: Invalid token from $(srcip)</description>
    <group>authentik,authentication_failed</group>
  </rule>

  <rule id="100114" level="12" frequency="10" timeframe="60">
    <if_matched_sid>100113</if_matched_sid>
    <same_source_ip/>
    <description>Authentik: Token brute force from $(srcip)</description>
    <group>authentik,brute_force</group>
    <mitre>
      <id>T1528</id>
    </mitre>
  </rule>

  <rule id="100115" level="3">
    <decoded_as>authentik-authorization</decoded_as>
    <description>Authentik: OIDC authorization for $(user) on $(extra_data)</description>
    <group>authentik,authorization</group>
  </rule>

</group>
