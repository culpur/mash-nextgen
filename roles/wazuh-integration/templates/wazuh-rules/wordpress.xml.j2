<!-- Managed by mash-nextgen — WordPress security rules -->
<group name="wordpress,web,authentication">

  <rule id="100200" level="10">
    <decoded_as>wordpress-xmlrpc</decoded_as>
    <description>WordPress: xmlrpc.php access from $(srcip) — potential brute force vector</description>
    <group>wordpress,attack</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <rule id="100201" level="12" frequency="5" timeframe="60">
    <if_matched_sid>100200</if_matched_sid>
    <same_source_ip/>
    <description>WordPress: xmlrpc.php brute force from $(srcip)</description>
    <group>wordpress,brute_force</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="100202" level="5">
    <decoded_as>wordpress-login-attempt</decoded_as>
    <description>WordPress: Login page access from $(srcip)</description>
    <group>wordpress,authentication</group>
  </rule>

  <rule id="100203" level="10" frequency="10" timeframe="300">
    <if_matched_sid>100202</if_matched_sid>
    <same_source_ip/>
    <description>WordPress: Login brute force from $(srcip)</description>
    <group>wordpress,brute_force</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="100204" level="5">
    <decoded_as>wordpress-admin-access</decoded_as>
    <description>WordPress: Admin panel access from $(srcip)</description>
    <group>wordpress,admin</group>
  </rule>

  <rule id="100205" level="3">
    <decoded_as>wordpress-rest-api</decoded_as>
    <description>WordPress: REST API access from $(srcip)</description>
    <group>wordpress,api</group>
  </rule>

</group>
